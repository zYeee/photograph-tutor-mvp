# LiveKit server connection (matches livekit.yaml dev keys)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# OpenAI — required for AI voice features; leave blank to run scaffold only
OPENAI_API_KEY=sk-...

# Database — SQLite default; swap to postgresql+asyncpg://user:pass@host/db for Postgres
DATABASE_URL=sqlite+aiosqlite:///./db/local.db

# Frontend — base URL the browser uses to reach the backend API
VITE_BACKEND_URL=http://localhost:8000
